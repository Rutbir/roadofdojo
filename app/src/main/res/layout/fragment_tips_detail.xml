<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wood_overlay"
    android:fillViewport="true"
    android:padding="20dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FCF8F3"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:gravity="center"
                android:text="💡"
                android:textSize="40sp" />

            <TextView
                android:id="@+id/tvTipsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="Judul Tips"
                android:textColor="#3E2723"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginVertical="16dp"
                android:background="#D7CCC8" />

            <TextView
                android:id="@+id/tvTipsBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Konten tips akan tampil di sini dengan penjelasan yang lebih detail dan nyaman dibaca."
                android:textColor="#5D4037"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvVideoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Video"
                android:textColor="#3E2723"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <android.webkit.WebView
                android:id="@+id/wvTipVideo"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="#000000"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.core.widget.NestedScrollView>
